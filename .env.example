# Cinemood Drive - Full-Stack Persistent Core Configuration

# Enable stable server-side database storage and direct GitHub Repository synchronization
# Set to 'production' for building and launching compiled production bundles
NODE_ENV=development

# --- GitHub JSON Storage Integration (Optional/Highly Recommended for Vercel) ---
# If configured, the backend will sync all links directly with your GitHub repository links.json file!
# If left draft/unconfigured, the backend falls back to local server-side files (data/links.json).

# Your GitHub Personal Access Token (PAT) with read/write repo access
GITHUB_TOKEN=your_github_personal_access_token

# The repository owner (GitHub username or organization name)
GITHUB_OWNER=your_github_username

# The repository name (e.g., cinemood-drive)
GITHUB_REPO=your_repository_name

# The branch (defaults to 'main' if left empty)
GITHUB_BRANCH=main
